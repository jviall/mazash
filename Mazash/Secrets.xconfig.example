ACRCLOUD_HOST = identify-[REGION].acrcloud.com
ACRCLOUD_ACCESS_KEY = YOUR_ACR_KEY
ACRCLOUD_ACCESS_SECRET = YOUR_ACR_SECRET

// Spotify — create an app at developer.spotify.com, set redirect URI to mazash://spotify
SPOTIFY_CLIENT_ID = YOUR_SPOTIFY_CLIENT_ID
SPOTIFY_PLAYLIST_ID = YOUR_SPOTIFY_PLAYLIST_ID

